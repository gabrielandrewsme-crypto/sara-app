EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# OPENAI_API_KEY is NOT defined here on purpose.
# It is a SERVER secret used only by the Supabase Edge Function "sara-chat".
# Set it in: Supabase Dashboard → Project Settings → Edge Functions → Secrets
#   Name:  OPENAI_API_KEY
#   Value: sk-...
# Optional: SARA_MODEL (defaults to "gpt-4o-mini")
